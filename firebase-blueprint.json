{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and application settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "emailOrPhone": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "currency": { "type": "string", "enum": ["BRL", "USD", "EUR", "MZN", "KZ"] },
            "language": { "type": "string", "enum": ["pt", "en"] },
            "lowStockThreshold": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "emailOrPhone"]
    },
    "StockEntry": {
      "title": "StockEntry",
      "description": "Record of a stock entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "brand": { "type": "string" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["3P", "Meio", "Completa"] },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["id", "date", "brand", "quantity", "type", "unitPrice", "totalPrice"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of a sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "brand": { "type": "string" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["3P", "Meio", "Completa"] },
        "price": { "type": "number" },
        "totalPrice": { "type": "number" },
        "customerId": { "type": "string" }
      },
      "required": ["id", "date", "brand", "quantity", "type", "price", "totalPrice", "customerId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "totalSpent": { "type": "number" },
        "lastPurchaseDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "totalSpent"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings."
    },
    "/users/{userId}/stockEntries/{entryId}": {
      "schema": "StockEntry",
      "description": "User's stock entries."
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "User's sales records."
    },
    "/users/{userId}/customers/{customerId}": {
      "schema": "Customer",
      "description": "User's customers."
    }
  }
}
